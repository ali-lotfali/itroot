<!DOCTYPE html>
<html lang="fa">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>نمایش IP کامپیوتر</title>
  <!-- Font Awesome برای آیکون دگمه (اختیاری) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(145deg, #f6f8fc 0%, #e9eef4 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 1.5rem;
      direction: rtl; /* پشتیبانی از زبان فارسی */
    }

    .workflow-card {
      max-width: 600px;
      width: 100%;
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 2rem;
      padding: 2.5rem 2rem;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15), 0 8px 16px rgba(0, 0, 0, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.3);
      transition: all 0.25s ease;
      text-align: center;
    }

    .workflow-card:hover {
      box-shadow: 0 30px 55px rgba(0, 0, 0, 0.18);
      transform: translateY(-3px);
    }

    h1 {
      font-size: 1.9rem;
      font-weight: 600;
      color: #1a2639;
      margin-bottom: 0.5rem;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    h1 i {
      color: #2a6f97;
      font-size: 2rem;
    }

    .subtitle {
      color: #3e4e62;
      font-size: 1rem;
      margin-bottom: 2.2rem;
      border-bottom: 2px dashed #b6c8d9;
      padding-bottom: 0.8rem;
      opacity: 0.8;
    }

    .ip-display-box {
      background: #0b1a2b;
      border-radius: 1.6rem;
      padding: 1.8rem 1rem;
      margin-bottom: 2.2rem;
      box-shadow: inset 0 5px 10px rgba(0,0,0,0.5), 0 8px 18px rgba(0, 20, 40, 0.3);
      border: 1px solid #2f4560;
      transition: all 0.3s;
    }

    .ip-display-box .ip-label {
      font-size: 0.9rem;
      color: #8ba3c7;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-weight: 400;
      display: block;
      margin-bottom: 6px;
    }

    .ip-address {
      font-size: 2.5rem;
      font-weight: 700;
      font-family: 'Courier New', monospace;
      color: #b9e6ff;
      word-break: break-word;
      text-shadow: 0 0 12px rgba(70, 170, 255, 0.4);
      letter-spacing: 1px;
      min-height: 4rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    .ip-address i {
      font-size: 1.8rem;
      color: #4c9aff;
      opacity: 0.7;
    }

    .ip-placeholder {
      color: #5f7b9c;
      font-weight: 400;
      font-size: 1.1rem;
      letter-spacing: 0.5px;
    }

    .btn-ip {
      background: #1b3b5a;
      border: none;
      padding: 1rem 2.2rem;
      border-radius: 60px;
      font-size: 1.25rem;
      font-weight: 600;
      color: #f0f9ff;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      transition: 0.2s ease;
      box-shadow: 0 8px 0 #0d2233, 0 10px 20px rgba(0, 0, 0, 0.2);
      border: 1px solid #3e6a8f;
      width: 100%;
      max-width: 280px;
      margin: 0 auto 0.5rem;
    }

    .btn-ip i {
      font-size: 1.5rem;
      color: #9bc9ff;
    }

    .btn-ip:hover {
      background: #254f72;
      transform: translateY(-2px);
      box-shadow: 0 10px 0 #0d2233, 0 16px 28px rgba(0, 0, 0, 0.25);
    }

    .btn-ip:active {
      transform: translateY(6px);
      box-shadow: 0 2px 0 #0d2233, 0 10px 18px rgba(0, 0, 0, 0.2);
    }

    .btn-ip:disabled {
      opacity: 0.6;
      transform: translateY(4px);
      box-shadow: 0 4px 0 #0d2233;
      pointer-events: none;
    }

    .status-message {
      margin-top: 1.5rem;
      font-size: 0.9rem;
      color: #2a4b6e;
      background: rgba(60, 130, 200, 0.08);
      padding: 0.5rem 1rem;
      border-radius: 40px;
      display: inline-block;
      backdrop-filter: blur(4px);
      border: 1px solid rgba(60, 130, 200, 0.15);
    }

    .status-message i {
      margin-left: 8px;
      color: #2a7faa;
    }

    .footer-note {
      margin-top: 1.8rem;
      font-size: 0.75rem;
      color: #5a6f86;
      opacity: 0.7;
    }

    /* حالت در حال بارگذاری */
    .loading-spinner {
      display: inline-block;
      width: 1.8rem;
      height: 1.8rem;
      border: 3px solid rgba(255, 255, 255, 0.2);
      border-top: 3px solid #7bb3ff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-left: 8px;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* واکنش‌گرایی */
    @media (max-width: 480px) {
      .workflow-card {
        padding: 1.8rem 1rem;
      }
      .ip-address {
        font-size: 1.8rem;
      }
      .btn-ip {
        font-size: 1.1rem;
        padding: 0.8rem 1.5rem;
        max-width: 220px;
      }
    }
  </style>
</head>
<body>

<div class="workflow-card">
  <h1>
    <i class="fas fa-network-wired"></i> 
    نمایش IP
  </h1>
  <div class="subtitle">کامپیوتر شما • دریافت آدرس عمومی</div>

  <!-- بخش نمایش IP -->
  <div class="ip-display-box">
    <span class="ip-label"><i class="fas fa-globe"></i> آدرس IP عمومی</span>
    <div id="ipAddress" class="ip-address">
      <i class="fas fa-circle-notch fa-spin" style="font-size: 1.4rem; opacity: 0.5;"></i>
      <span class="ip-placeholder">دریافت نشده</span>
    </div>
  </div>

  <!-- دگمه اصلی -->
  <button id="fetchIpBtn" class="btn-ip">
    <i class="fas fa-sync-alt"></i> 
    نمایش IP کامپیوتر
  </button>

  <!-- وضعیت/خطا -->
  <div id="statusMessage" class="status-message">
    <i class="fas fa-info-circle"></i> 
    برای دریافت IP کلیک کنید
  </div>

  <div class="footer-note">
    <i class="fas fa-shield-alt"></i> 
    اطلاعات صرفاً از سرویس عمومی ipify دریافت می‌شود
  </div>
</div>

<script>
  (function() {
    // عناصر DOM
    const ipDisplay = document.getElementById('ipAddress');
    const fetchBtn = document.getElementById('fetchIpBtn');
    const statusMsg = document.getElementById('statusMessage');

    // تابع کمکی برای به‌روزرسانی وضعیت
    function setStatus(text, type = 'info') {
      statusMsg.innerHTML = '';
      const icon = document.createElement('i');
      if (type === 'info') {
        icon.className = 'fas fa-info-circle';
        statusMsg.style.color = '#2a4b6e';
      } else if (type === 'success') {
        icon.className = 'fas fa-check-circle';
        statusMsg.style.color = '#1b7a3d';
      } else if (type === 'error') {
        icon.className = 'fas fa-exclamation-triangle';
        statusMsg.style.color = '#b13e3e';
      } else if (type === 'loading') {
        icon.className = 'fas fa-spinner fa-pulse';
        statusMsg.style.color = '#2a6f97';
      }
      statusMsg.appendChild(icon);
      statusMsg.appendChild(document.createTextNode(' ' + text));
    }

    // تابع اصلی دریافت IP
    async function fetchIp() {
      // غیرفعال کردن دگمه در حین درخواست
      fetchBtn.disabled = true;
      fetchBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> در حال دریافت...';

      // نمایش وضعیت در حال بارگذاری
      setStatus('در حال دریافت آدرس IP ...', 'loading');

      // تغییر نمایش IP به حالت waiting
      ipDisplay.innerHTML = `
        <i class="fas fa-circle-notch fa-spin" style="font-size: 1.6rem; opacity: 0.6;"></i>
        <span class="ip-placeholder">دریافت ...</span>
      `;

      try {
        // استفاده از API عمومی ipify (با پشتیبانی از IPv4 و IPv6)
        // برای اطمینان از دریافت IPv4 از مسیر ?format=json استفاده می‌کنیم
        const response = await fetch('https://api.ipify.org?format=json', {
          method: 'GET',
          headers: { 'Accept': 'application/json' }
        });

        if (!response.ok) {
          throw new Error(`خطای HTTP ${response.status} - ${response.statusText}`);
        }

        const data = await response.json();
        
        // بررسی وجود ip در پاسخ
        if (data && data.ip) {
          const ip = data.ip;
          // نمایش IP زیبا
          ipDisplay.innerHTML = `
            <i class="fas fa-wifi" style="font-size: 1.8rem; color: #6db3ff;"></i>
            <span style="margin-left: 6px;">${ip}</span>
          `;
          setStatus(`IP دریافت شد: ${ip}`, 'success');
        } else {
          throw new Error('پاسخ API فاقد آدرس IP است');
        }

      } catch (error) {
        // خطا: نمایش پیام خطا در باکس IP و وضعیت
        console.error('خطا در دریافت IP:', error);
        ipDisplay.innerHTML = `
          <i class="fas fa-exclamation-circle" style="color: #ff8a8a; font-size: 2rem;"></i>
          <span style="color: #ffb3b3; font-size: 1.1rem; margin-left: 6px;">خطا در دریافت</span>
        `;
        setStatus(`خطا: ${error.message || 'مشکل در ارتباط با سرور'}`, 'error');
      } finally {
        // فعال کردن دگمه و برگرداندن متن آن
        fetchBtn.disabled = false;
        fetchBtn.innerHTML = '<i class="fas fa-sync-alt"></i> نمایش IP کامپیوتر';
      }
    }

    // افزودن event listener به دگمه
    fetchBtn.addEventListener('click', fetchIp);

    // (اختیاری) اجرای خودکار برای نمایش IP هنگام بارگذاری صفحه
    // غیرفعال کردن خودکار برای رعایت تجربه کاربری (با دگمه انجام می‌شود)
    // ولی اگر بخواهید یکبار خودکار نمایش دهد، خط زیر را فعال کنید:
    // fetchIp();

    // نمایش راهنما در حالت اولیه
    setStatus('برای دریافت IP روی دگمه کلیک کنید', 'info');
  })();
</script>

<!-- توضیح: این کد یک ورکفلور ساده با دگمه نمایش IP است.
     از API عمومی ipify.org برای دریافت IP استفاده می‌کند.
     کاملاً ریسپانسیو، دارای افکت‌های مدرن و حالت‌های خطا/بارگذاری. -->
</body>
</html>
